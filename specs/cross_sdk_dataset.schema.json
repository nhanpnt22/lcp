{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nhanpnt22.github.io/lcp/schemas/cross_sdk_dataset.schema.json",
  "title": "LCP Cross-SDK Dataset",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "namespace",
      "operation_id",
      "payload",
      "schema_version",
      "spec_checksum",
      "user_scope",
      "value"
    ],
    "properties": {
      "namespace": {
        "type": "string",
        "minLength": 1
      },
      "operation_id": {
        "type": "string",
        "minLength": 1
      },
      "payload": {
        "type": "object"
      },
      "schema_version": {
        "type": "string",
        "minLength": 1
      },
      "spec_checksum": {
        "type": "string",
        "minLength": 1
      },
      "user_scope": {
        "type": "string",
        "minLength": 1
      },
      "value": {
        "type": "string"
      }
    }
  }
}
