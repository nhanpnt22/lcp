# NodeJS LCP SDK example env (Firebase App Hosting friendly)
LCP_PERSISTENT_ENABLED=true
LCP_PERSISTENCE_MODE=dual
LCP_PERSISTENCE_SHORT_THRESHOLD_MS=300000

# local | cloud-run
LCP_RUNTIME_MODE=local

# Local backend: in-memory | sqlite | cloud-storage
LCP_LOCAL_BACKEND=sqlite

LCP_CACHE_PATH=lcp
LCP_LOCAL_CACHE_ROOT=./config
LCP_SQLITE_PATH=./config/lcp/lcp_cache.db

# Cloud Run backend split
LCP_CLOUD_RUN_BACKEND_PREFERENCE=storage
LCP_IN_MEMORY_BACKEND=in-memory
LCP_STORAGE_BACKEND=sqlite

# Cloud Storage backend inputs
LCP_STORAGE_BUCKET_URI=gs://aiptesting.firebasestorage.app
LCP_STORAGE_GCS_URI=gs://aiptesting.firebasestorage.app/lcp
GOOGLE_CLOUD_PROJECT=aiptesting
# GCP_SA_KEY=/absolute/path/to/key.json
