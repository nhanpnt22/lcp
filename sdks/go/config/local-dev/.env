ENV=local-dev
GOOGLE_CLOUD_PROJECT=aiptesting
GCP_SA_KEY=config/local-dev/aiptesting-firebase-adminsdk-fbsvc-398b4932fd.json

# ----------------------------
# LCP Go SDK persistent config
# ----------------------------
LCP_PERSISTENT_ENABLED=true

# JS-consistent persistence policy: dual | memory-only | auto
LCP_PERSISTENCE_MODE=dual
LCP_PERSISTENCE_SHORT_THRESHOLD_MS=300000

# Runtime switch: local | cloud-run
LCP_RUNTIME_MODE=local

# Shared cache path for local sqlite defaults and bucket prefix derivation.
LCP_CACHE_PATH=lcp
LCP_LOCAL_CACHE_ROOT=./config
LCP_SQLITE_PATH=${LCP_LOCAL_CACHE_ROOT}/${LCP_CACHE_PATH}/lcp_cache.db

# Cloud Run backend split (finalized):
# in-memory: in-memory
# storage: sqlite | cloud-storage
LCP_IN_MEMORY_BACKEND=in-memory
LCP_STORAGE_BACKEND=sqlite
LCP_CLOUD_RUN_BACKEND_PREFERENCE=storage

# Optional bucket reference for verification commands/scripts.
LCP_STORAGE_BUCKET_URI=gs://aiptesting.firebasestorage.app
# Direct Cloud Storage target URI for cloud-storage backend.
LCP_STORAGE_GCS_URI=gs://aiptesting.firebasestorage.app/lcp

# Example profiles:
# 1) Local in-memory:
# LCP_RUNTIME_MODE=local
# LCP_LOCAL_BACKEND=in-memory
#
# 2) Local sqlite:
# LCP_RUNTIME_MODE=local
# LCP_LOCAL_BACKEND=sqlite
# LCP_SQLITE_PATH=./config/lcp/lcp_cache.db
#
# 3) Local cloud storage:
# LCP_RUNTIME_MODE=local
# LCP_LOCAL_BACKEND=cloud-storage
# LCP_STORAGE_GCS_URI=gs://aiptesting.firebasestorage.app/lcp
#
# 4) Cloud Run in-memory:
# LCP_RUNTIME_MODE=cloud-run
# LCP_CLOUD_RUN_BACKEND_PREFERENCE=in-memory
# LCP_IN_MEMORY_BACKEND=in-memory
#
# 5) Cloud Run sqlite:
# LCP_RUNTIME_MODE=cloud-run
# LCP_CLOUD_RUN_BACKEND_PREFERENCE=storage
# LCP_STORAGE_BACKEND=sqlite
# LCP_SQLITE_PATH=/tmp/lcp/lcp_cache.db
#
# 6) Cloud Run cloud storage:
# LCP_RUNTIME_MODE=cloud-run
# LCP_CLOUD_RUN_BACKEND_PREFERENCE=storage
# LCP_STORAGE_BACKEND=cloud-storage
# LCP_STORAGE_GCS_URI=gs://aiptesting.firebasestorage.app/lcp
